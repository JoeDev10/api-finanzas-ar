PORT=3000
NODE_ENV=development

# Supabase — para API keys y datos históricos (opcional)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# Clave admin si no usás Supabase
ADMIN_API_KEY=cambiame_por_algo_seguro

# RapidAPI — secreto del proxy (configurar en Vercel + RapidAPI dashboard)
# Sin este valor el middleware es no-op (útil para dev/directo)
RAPIDAPI_PROXY_SECRET=
